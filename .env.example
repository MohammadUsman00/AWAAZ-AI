# Required for POST /api/analyze (get a key from https://aistudio.google.com/apikey )
GEMINI_API_KEY=

# Server
PORT=8080

# Model id (must match a model your key can call)
GEMINI_MODEL=gemini-2.0-flash

# Max output tokens for Gemini
GEMINI_MAX_TOKENS=2048

# Optional: if set, GET /api/complaints requires: Authorization: Bearer <ADMIN_TOKEN>
# Leave unset for open demo list (not recommended in production)
# ADMIN_TOKEN=

# Max complaints kept in data/complaints.json
COMPLAINTS_MAX_STORED=500

# Rate limit: max analyze requests per IP per 15 minutes
RATE_LIMIT_ANALYZE=40

# CORS: omit or use * for reflect; set to your frontend origin in production
# CORS_ORIGIN=*
