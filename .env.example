# Required
GEMINI_API_KEY=
# Google AI Studio — free tier (https://aistudio.google.com/apikey)

GROQ_API_KEY=
# Groq console — free Whisper (https://console.groq.com)

RESEND_API_KEY=
# Resend — free 3000 emails/month (https://resend.com)

# Optional
ADMIN_TOKEN=
# Protects GET /api/complaints, DELETE/PATCH, and /admin (Basic: user admin, password = ADMIN_TOKEN)

EMAIL_SECRET=
# 32+ character secret for AES-256-GCM email storage (generate a random string)

PUBLIC_BASE_URL=
# Public site HTTPS URL (required on Render for email PDF links), e.g. https://awaaz-ai.onrender.com

PORT=8080
NODE_ENV=development
LOG_LEVEL=info
GEMINI_MODEL=gemini-2.0-flash
GEMINI_MAX_TOKENS=1500
RATE_LIMIT_ANALYZE=40
COMPLAINTS_MAX_STORED=10000
# Local: relative path. On Render with disk at /data: use DB_PATH=/data/awaaz.db (see render.yaml)
DB_PATH=data/awaaz.db
# Same-origin deploy: * is fine. Split frontend/API: set to your site origin
CORS_ORIGIN=*
